# EnvironmentGPT runtime environment variables
# Copy to `.env.local` for development or `.env.production` for deployment.

# Core application
NODE_ENV=development
PORT=3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Database
# Replace the password and host values to match your local PostgreSQL instance.
DATABASE_URL=postgresql://postgres:replace-with-your-postgres-password@127.0.0.1:5432/environmentgpt?schema=public

# Seeded LLM provider endpoints
VLLM_BASE_URL=http://localhost:8000/v1
VLLM_FALLBACK_URL=http://localhost:8001/v1
VLLM_FALLBACK2_URL=http://localhost:8002/v1

# Seeded live-data connector endpoints and API keys
AQI_API_URL=https://api.waqi.info/feed/punjab/
AQI_API_KEY=replace-with-your-waqi-token
WEATHER_API_URL=https://api.openweathermap.org/data/2.5/weather
WEATHER_API_KEY=replace-with-your-openweather-token

# Global rate limiting
RATE_LIMIT_WINDOW=60000
RATE_LIMIT_MAX=60
RATE_LIMIT_BLOCK_DURATION=60000

# Chat-specific rate limiting
RATE_LIMIT_CHAT_WINDOW=60000
RATE_LIMIT_CHAT_MAX=20
RATE_LIMIT_CHAT_BLOCK_DURATION=60000

# Upload-specific rate limiting
RATE_LIMIT_UPLOAD_WINDOW=3600000
RATE_LIMIT_UPLOAD_MAX=10
RATE_LIMIT_UPLOAD_BLOCK_DURATION=1800000

# Auth/admin-specific rate limiting
RATE_LIMIT_AUTH_WINDOW=900000
RATE_LIMIT_AUTH_MAX=5
RATE_LIMIT_AUTH_BLOCK_DURATION=1800000

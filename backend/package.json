{
  "name": "@environmentgpt/backend",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev --webpack -p 3001",
    "build": "next build",
    "start": "NODE_ENV=production node .next/standalone/server.js",
    "db:init": "node ../scripts/ensure-prisma-db.cjs",
    "db:push": "npm run db:init && prisma db push",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:reset": "prisma migrate reset",
    "db:seed": "tsx ../scripts/seed.ts",
    "db:setup": "npm run db:init && prisma generate && prisma db push && tsx ../scripts/seed.ts"
  },
  "prisma": {
    "seed": "tsx ../scripts/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "^6.11.1",
    "enhanced-resolve": "^5.18.4",
    "mammoth": "^1.12.0",
    "next": "^16.1.1",
    "pdf-parse": "^2.4.5",
    "prisma": "^6.11.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "sharp": "^0.34.3",
    "uuid": "^11.1.0",
    "word-extractor": "^1.0.4",
    "zod": "^4.0.2"
  },
  "devDependencies": {
    "typescript": "^5"
  }
}

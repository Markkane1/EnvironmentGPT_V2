{
  "name": "@environmentgpt/backend",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev --webpack -p 3001",
    "build": "node ../scripts/prisma-cli.cjs generate && next build",
    "start": "NODE_ENV=production node .next/standalone/server.js",
    "db:init": "node ../scripts/ensure-prisma-db.cjs",
    "db:push": "npm run db:init && node ../scripts/prisma-cli.cjs db push",
    "db:generate": "node ../scripts/prisma-cli.cjs generate",
    "db:migrate": "node ../scripts/prisma-cli.cjs migrate dev",
    "db:reset": "node ../scripts/prisma-cli.cjs migrate reset",
    "db:seed": "tsx ../scripts/seed.ts",
    "db:setup": "npm run db:init && node ../scripts/prisma-cli.cjs generate && node ../scripts/prisma-cli.cjs db push && tsx ../scripts/seed.ts"
  },
  "prisma": {
    "seed": "tsx ../scripts/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "^6.11.1",
    "bcryptjs": "^3.0.3",
    "enhanced-resolve": "^5.18.4",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "mammoth": "^1.12.0",
    "next": "^16.1.7",
    "pdf-parse": "^2.4.5",
    "prisma": "^6.11.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "sharp": "^0.34.3",
    "uuid": "^11.1.0",
    "word-extractor": "^1.0.4",
    "zod": "^4.0.2"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "typescript": "^5"
  }
}

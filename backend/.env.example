# Backend runtime configuration
# Copy to `backend/.env` or export these variables in your deployment environment.

# Application mode
NODE_ENV=development
PORT=3001
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Database
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5432/environmentgpt?schema=public

# Authentication
JWT_SECRET=replace-with-a-long-random-secret
ADMIN_API_KEY=replace-with-an-admin-api-key

# Optional provider endpoints
VLLM_BASE_URL=http://localhost:8000/v1
VLLM_FALLBACK_URL=http://localhost:8001/v1
VLLM_FALLBACK2_URL=http://localhost:8002/v1

# Optional connector endpoints and API keys
AQI_API_URL=https://api.example.com/air-quality
AQI_API_KEY=replace-with-your-aqi-api-key
WEATHER_API_URL=https://api.example.com/weather
WEATHER_API_KEY=replace-with-your-weather-api-key

# Rate limiting
RATE_LIMIT_WINDOW=60000
RATE_LIMIT_MAX=100
RATE_LIMIT_BLOCK_DURATION=60000
RATE_LIMIT_CHAT_WINDOW=60000
RATE_LIMIT_CHAT_MAX=20
RATE_LIMIT_CHAT_BLOCK_DURATION=60000
RATE_LIMIT_UPLOAD_WINDOW=3600000
RATE_LIMIT_UPLOAD_MAX=10
RATE_LIMIT_UPLOAD_BLOCK_DURATION=1800000
RATE_LIMIT_ADMIN_WINDOW=60000
RATE_LIMIT_ADMIN_MAX=30
RATE_LIMIT_ADMIN_BLOCK_DURATION=300000
RATE_LIMIT_AUTH_WINDOW=60000
RATE_LIMIT_AUTH_MAX=10
RATE_LIMIT_AUTH_BLOCK_DURATION=1800000

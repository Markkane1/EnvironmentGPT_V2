{
  "name": "epa-punjab-environmentgpt",
  "version": "1.0.0",
  "private": true,
  "description": "EPA Punjab EnvironmentGPT - AI-powered environmental knowledge assistant with vLLM integration",
  "workspaces": [
    "frontend",
    "backend"
  ],
  "scripts": {
    "clean": "node scripts/clean.cjs",
    "clean:all": "node scripts/clean.cjs --deps",
    "dev": "node scripts/dev.cjs",
    "dev:frontend": "npm run dev --workspace=frontend",
    "dev:backend": "npm run dev --workspace=backend",
    "build": "npm run build --workspace=backend && npm run build --workspace=frontend",
    "build:frontend": "npm run build --workspace=frontend",
    "build:backend": "npm run build --workspace=backend",
    "lint": "eslint frontend/src backend/src",
    "test": "jest --config tests/config/jest.config.ts",
    "test:watch": "jest --config tests/config/jest.config.ts --watch",
    "test:coverage": "jest --config tests/config/jest.config.ts --coverage",
    "test:ci": "jest --config tests/config/jest.config.ts --ci --coverage --reporters=default",
    "test:unit": "jest --config tests/config/jest.backend.config.ts tests/unit",
    "test:integration": "jest --config tests/config/jest.backend.config.ts tests/integration",
    "test:components": "jest --config tests/config/jest.frontend.config.ts tests/components",
    "test:security": "jest --config tests/config/jest.backend.config.ts tests/security",
    "test:e2e": "playwright test --config tests/config/playwright.config.ts",
    "db:init": "node scripts/ensure-prisma-db.cjs",
    "db:push": "npm run db:init && node scripts/prisma-cli.cjs db push",
    "db:generate": "node scripts/prisma-cli.cjs generate",
    "db:migrate": "node scripts/prisma-cli.cjs migrate dev",
    "db:reset": "node scripts/prisma-cli.cjs migrate reset",
    "db:seed": "tsx scripts/seed.ts",
    "db:setup": "npm run db:init && node scripts/prisma-cli.cjs generate && node scripts/prisma-cli.cjs db push && tsx scripts/seed.ts",
    "providers:check": "tsx -e \"import { llmProviderRegistry } from './backend/src/lib/services/llm-provider-registry'; llmProviderRegistry.healthCheckAll().then(console.log)\""
  },
  "prisma": {
    "seed": "tsx scripts/seed.ts"
  },
  "dependencies": {
    "next": "^16.2.1",
    "next-auth": "^4.24.11"
  },
  "devDependencies": {
    "@swc/helpers": "^0.5.15",
    "@next/eslint-plugin-next": "^16.2.1",
    "@playwright/test": "^1.58.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/jest": "^30.0.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "bun-types": "^1.3.4",
    "cross-fetch": "^4.1.0",
    "es-iterator-helpers": "^1.3.1",
    "eslint": "^9",
    "eslint-config-next": "^16.1.7",
    "fast-glob": "^3.3.1",
    "identity-obj-proxy": "^3.0.0",
    "jest": "^30.3.0",
    "jest-environment-jsdom": "^30.3.0",
    "jsonwebtoken": "^9.0.3",
    "node-mocks-http": "^1.17.2",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "typescript": "^5"
  },
  "overrides": {
    "@eslint/config-array": {
      "minimatch": "^3.1.4"
    },
    "@eslint/eslintrc": {
      "minimatch": "^3.1.4"
    },
    "@typescript-eslint/typescript-estree": {
      "minimatch": "^9.0.7"
    },
    "eslint": {
      "minimatch": "^3.1.4"
    },
    "eslint-plugin-import": {
      "minimatch": "^3.1.4"
    },
    "eslint-plugin-jsx-a11y": {
      "minimatch": "^3.1.4"
    },
    "eslint-plugin-react": {
      "minimatch": "^3.1.4"
    },
    "test-exclude": {
      "minimatch": "^3.1.4"
    },
    "ajv": "^6.14.0",
    "flatted": "^3.4.2",
    "lodash": "^4.17.22",
    "lodash-es": "^4.17.22"
  }
}
